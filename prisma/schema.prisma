// 特案支援金報備系統 — 資料模型
// 雛型階段使用 SQLite；上雲時將 provider 改為 postgresql 並把字串狀態改為 enum。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 人員主檔：帳號 ↔ 據點 ↔ 課別 ↔ 角色
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  role         String // KEZHANG(課長) | SUOZHANG(所長) | BUZHUGUAN(部主管) | STAFF
  storeCode    String // 所別 Dxx
  deptCode     String? // 課別（部主管/staff 可為空）
  systems      String   @default("fund") // 可用系統，逗號分隔（見 src/lib/constants.ts 的 SYSTEM）
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  submittedCases Case[]        @relation("submitter")
  approvals      ApprovalLog[]
}

// 案件（申請單）
model Case {
  id          String @id @default(cuid())
  month       String // 月份 YYYY-MM（自動帶入）
  storeCode   String // 所別（依送單人帶出）
  deptCode    String // 課別（依送單人帶出）
  plateName   String // 領牌名稱
  orderNo     String @unique // 訂單編號：13碼、第一碼 D、全系統唯一
  categoryId  String? // 特案類別（草稿可留空）
  categoryNo  String // 類別編號（人工填入）
  carModel    String // 車名
  description String // 特案內容說明

  // 金額（整數）
  subsidyDeptCourse Int // 所課支援金
  goldMedal         Int // 金牌
  silverMedal       Int // 銀牌
  discountTotal     Int // 折讓總額
  specialSubsidy    Int // 特案支援金額（可為 0）

  // 流程狀態
  status        String // DRAFT | PENDING_SUOZHANG | PENDING_BUZHUGUAN | APPROVED | REJECTED | WITHDRAWN
  submittedById String
  submittedBy   User     @relation("submitter", fields: [submittedById], references: [id])
  submittedAt   DateTime @default(now())
  stepEnteredAt DateTime @default(now()) // 進入目前關卡的時間（逾期判斷用）
  updatedAt     DateTime @updatedAt

  category CaseCategory? @relation(fields: [categoryId], references: [id])
  logs     ApprovalLog[]

  @@index([status])
  @@index([storeCode])
  @@index([month])
}

// 審核／異動紀錄（稽核軌跡）
model ApprovalLog {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id])
  step       String // SUBMIT | RESUBMIT | WITHDRAW | SUOZHANG | BUZHUGUAN
  action     String // SUBMIT | RESUBMIT | WITHDRAW | APPROVE | REJECT
  reviewerId String
  reviewer   User     @relation(fields: [reviewerId], references: [id])
  comment    String? // 審核意見 / 駁回原因
  createdAt  DateTime @default(now())

  @@index([caseId])
}

// 特案類別主檔
model CaseCategory {
  id        String  @id @default(cuid())
  name      String  @unique
  active    Boolean @default(true)
  sortOrder Int     @default(0)
  cases     Case[]
}

// 車種主檔
model CarModel {
  id        String  @id @default(cuid())
  name      String  @unique
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}

// 月份開放/關閉設定
model MonthWindow {
  id      String    @id @default(cuid())
  month   String    @unique // YYYY-MM
  isOpen  Boolean   @default(true)
  openAt  DateTime?
  closeAt DateTime?
}

// 所課目標台數主檔：每月由後台整批上傳（覆蓋當月舊資料），逐所逐課設定比重與目標台數。
// deptCode="0" 代表「所層級」的獨立數值（業務編制沒有 0 課），不是靠加總底下各課算出來——
// 所目標與課目標各自獨立維護，互不連動。
model UnitTarget {
  id          String   @id @default(cuid())
  month       String // YYYY-MM
  storeCode   String // 所別
  deptCode    String // 課別；"0"="所層級"（無此課別編號）
  weight      Float // 比重（%）
  targetCount Int // 目標台數
  updatedAt   DateTime @updatedAt

  @@unique([month, storeCode, deptCode])
  @@index([month])
}
